{
  "name": "fuel-frog-panic",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev -p 3010",
    "build": "next build",
    "start": "next start -p 3010",
    "test": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs --test",
    "test:nodes": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs --test 'src/app/api/nodes/__tests__/**/*.test.ts' 'src/server/__tests__/nodeRuntime.test.ts' 'src/server/__tests__/nodeIndexerRuntime.test.ts'",
    "test:nodes:api": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs --test src/app/api/nodes/__tests__/route.test.ts",
    "test:nodes:runtime": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs --test src/server/__tests__/nodeRuntime.test.ts",
    "test:nodes:indexer": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs --test src/server/__tests__/nodeIndexerRuntime.test.ts",
    "lint": "next lint",
    "lint:imports": "node ./scripts/check-layer-imports.mjs",
    "test:refund-api": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs --test src/server/matchRuntime.refund.test.ts",
    "test:f007": "node ./scripts/test-f007.mjs",
    "typecheck": "tsc --noEmit",
    "verify:arch": "pnpm build && pnpm lint:imports",
    "verify": "pnpm verify:arch",
    "qa:all": "node ./scripts/qa/run-all.mjs",
    "qa:state-machine": "node ./scripts/qa/check-match-state-machine.mjs",
    "qa:settlement": "node ./scripts/qa/check-settlement-rules.mjs",
    "qa:whitelist": "node ./scripts/qa/check-whitelist-after-pay.mjs",
    "qa:ui-rules": "node ./scripts/qa/check-ui-team-rules-consistency.mjs",
    "qa:integration": "node ./scripts/qa/check-integration-lobby-lock-pay-running-settled.mjs",
    "qa:settlement-trace": "node ./scripts/qa/check-settlement-chain-trace.mjs",
    "verify:contract:devnet": "bash ./scripts/devnet-verify.sh",
    "index:nodes": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs --env-file=.env ./workers/nodeIndexer.ts",
    "index:nodes:once": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs --env-file=.env -e \"import('./src/server/nodeIndexerRuntime.ts').then((m) => m.syncNodeIndexOnce())\"",
    "solar-systems:test": "node ./scripts/test-solar-systems-api.mjs",
    "worker:node-runtime": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs ./workers/nodeRuntime.ts",
    "worker:constellation-runtime": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs ./workers/constellationRuntime.ts",
    "worker:match-runtime": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs ./workers/matchRuntime.ts",
    "worker:chain-sync": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs ./workers/chainSyncEngine.ts",
    "worker:settlement-runtime": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs ./workers/settlementRuntime.ts",
    "worker:supervisor": "node --experimental-strip-types --import ./scripts/register-test-loader.mjs ./workers/runtimeSupervisor.ts"
  },
  "dependencies": {
    "@mysten/dapp-kit-react": "^2.0.1",
    "@mysten/sui": "^2.9.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.183.1",
    "next": "15.3.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "three": "^0.183.2",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@types/node": "22.15.17",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.3",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  }
}
